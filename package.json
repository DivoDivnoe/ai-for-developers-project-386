{
  "name": "ai-for-developers-project-386",
  "private": true,
  "packageManager": "pnpm@10.28.2",
  "engines": {
    "node": ">=24",
    "pnpm": ">=10"
  },
  "scripts": {
    "spec:compile": "pnpm -C spec compile",
    "spec:watch": "pnpm -C spec watch",
    "lint": "eslint . && pnpm -r run --if-present lint",
    "lint:fix": "eslint . --fix && pnpm -r run --if-present lint:fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "pnpm -r run --if-present typecheck",
    "test": "pnpm -r run --if-present test",
    "test:e2e": "pnpm exec playwright test --config e2e/playwright.config.ts",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.61.1",
    "@types/node": "26.0.0",
    "@vitest/coverage-v8": "4.1.9",
    "eslint": "10.5.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-import-resolver-typescript": "4.4.5",
    "eslint-plugin-import-x": "4.16.2",
    "eslint-plugin-prefer-arrow-functions": "3.9.1",
    "husky": "9.1.7",
    "lint-staged": "17.0.7",
    "prettier": "3.8.4",
    "typescript": "5.9.3",
    "typescript-eslint": "8.61.1",
    "vitest": "4.1.9"
  }
}
