{
  "name": "backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "verify": "pnpm typecheck && pnpm lint && pnpm test",
    "gen:api": "openapi-typescript ../openapi/openapi.1.0.0.yaml -o generated/schema.ts"
  },
  "dependencies": {
    "@hono/zod-validator": "0.8.0",
    "date-fns": "4.4.0",
    "hono": "4.11.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "openapi-typescript": "7.13.0",
    "tsx": "4.19.0",
    "typescript": "5.9.3",
    "vitest": "4.1.9"
  }
}
