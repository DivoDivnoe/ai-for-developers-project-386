{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "typecheck": "tsc",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint-staged": "lint-staged",
    "verify": "pnpm typecheck && pnpm lint && pnpm test",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "gen:api": "openapi-typescript ../openapi/openapi.1.0.0.yaml -o src/api/schema.d.ts",
    "mock": "prism mock ../openapi/openapi.1.0.0.yaml -p 4010 -h 0.0.0.0",
    "mock:watch": "pnpm mock -- --watch",
    "dev": "vite",
    "build": "pnpm typecheck && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@fontsource-variable/geist": "5.2.9",
    "@tailwindcss/vite": "4.3.1",
    "@tanstack/react-query": "^5.59.0",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "date-fns": "4.4.0",
    "lucide-react": "1.21.0",
    "openapi-fetch": "0.17.0",
    "radix-ui": "1.6.0",
    "react": "19.2.7",
    "react-day-picker": "10.0.1",
    "react-dom": "19.2.7",
    "react-router-dom": "7.18.0",
    "sonner": "2.0.7",
    "tailwind-merge": "3.6.0",
    "tailwindcss": "4.3.1",
    "tw-animate-css": "1.4.0"
  },
  "devDependencies": {
    "@eslint-react/eslint-plugin": "5.9.1",
    "@stoplight/prism-cli": "5.15.11",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-react-hooks": "7.1.1",
    "jsdom": "29.1.1",
    "openapi-typescript": "7.13.0",
    "shadcn": "4.11.0",
    "typescript": "5.9.3",
    "vite": "8.0.16"
  }
}
